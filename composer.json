{
    "name": "daniel-km/omeka-s-module-timeline",
    "type": "omeka-s-module",
    "description": "Module for Omeka S: Integrate the Simile Timeline and the Knightlab Timeline to create advanced timelines from the dates of items.",
    "keywords": [
        "Omeka S",
        "Omeka S module",
        "timeline",
        "chronology",
        "data visualization"
    ],
    "license": "CECILL-2.1",
    "homepage": "https://gitlab.com/Daniel-KM/Omeka-S-module-Timeline",
    "authors": [
        {
            "name": "Daniel Berthereau",
            "email": "Daniel.packagist@Berthereau.net"
        }
    ],
    "support": {
        "issues": "https://gitlab.com/Daniel-KM/Omeka-S-module-Timeline/-/issues",
        "forum": "https://forum.omeka.org/"
    },
    "_require (not set until Omeka S merges PR #2412)": {
        "omeka/omeka-s": "^4.1",
        "daniel-km/omeka-s-module-common": "*"
    },
    "require": {
        "ext-xml": "*",
        "openspout/openspout": "^4.25"
    },
    "autoload": {
        "psr-4": {
            "Timeline\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "TimelineTest\\": "tests/TimelineTest/"
        }
    },
    "config": {
        "platform": {
            "php": "8.1"
        },
        "allow-plugins": {
            "composer/installers": true,
            "oomphinc/composer-installers-extender": true
        }
    },
    "extra": {
        "installer-name": "Timeline"
    }
}
